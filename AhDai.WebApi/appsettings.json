{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "File": {
    "UploadDirectory": "uploads",
    "DownloadDirectory": "downloads",
    "ExportDirectory": "exports",
    "MaxLength": "52428800", /*KB*/
    "Extensions": {
      "Image": [ ".bmp", ".jpg", ".jpeg", ".png", ".gif", ".heif" ],
      "Video": [ ".mp4", ".mkv", ".mov", ".avi" ],
      "File": [ ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx", ".pdf", ".txt", ".zip", ".rar", ".7z" ]
    },
    "ComputeHash": true
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [],
  "KestrelServerLimits": {
    "MaxRequestBodySize": 60000000 /*默认30,000,000/28.7MB*/
  }
}
